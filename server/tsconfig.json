{
  "compilerOptions": {
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "target": "ES6",
    "module": "commonjs",
    "outDir": "./dist", // Added a common outDir
    "rootDir": "./",    // Added rootDir
    "strict": true,     // Enable strict type-checking
    "skipLibCheck": true // Skip type checking of declaration files
  },
  "include": [
    "**/*.ts" // Include all .ts files in the server directory and subdirectories
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts", // Exclude test files from main compilation if they are handled by Jest separately
    "jest.config.ts"
  ]
}


