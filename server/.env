# MongoDB Configuration
# For MongoDB Atlas (Recommended - Free Tier Available)
# Get your connection string from: https://cloud.mongodb.com
# Example: MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/omega-db?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/omega-db

# For local development with Docker:
# MONGO_URI=mongodb://localhost:27017/omega-db

# For production (use environment-specific values):
# MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/omega-db?retryWrites=true&w=majority

# JWT Secret Key (CHANGE IN PRODUCTION!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-please-make-it-very-long-and-random

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: Database Configuration
DB_NAME=omega-db
DB_MAX_POOL_SIZE=10

# Optional: JWT Configuration
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Optional: CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1:3000

# Optional: Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# Optional: Security Headers
SECURITY_ENABLED=true

# Optional: Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Session Configuration (if using sessions)
SESSION_SECRET=another-super-secret-session-key-change-this-too

# Email Configuration (for future features)
# EMAIL_SERVICE=gmail
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# Cloud Storage (for future features)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_BUCKET_NAME=your-s3-bucket-name
# AWS_REGION=us-east-1

# Redis Configuration (for caching - future feature)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# API Keys (for external services)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# STRIPE_SECRET_KEY=your-stripe-secret-key


